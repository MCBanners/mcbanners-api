{
  "name": "mcbanners-api-next",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @mcbanners/api dev",
    "build": "tsc -b tsconfig.build.json",
    "test": "bun test apps packages",
    "test:compat": "bun test packages/domain/test",
    "test:visual": "bun -e \"console.log('Visual tests are not implemented in Milestone 1.')\"",
    "test:integration": "bun test tests/integration",
    "compat:compare": "bun --filter @mcbanners/compat-runner compare",
    "compat:compare:help": "bun --filter @mcbanners/compat-runner compare:help",
    "docker:build": "docker build -t mcbanners-api-next:local .",
    "docker:run": "docker run --rm -p 3000:3000 --env PORT=3000 mcbanners-api-next:local",
    "docker:smoke": "bun -e \"const r=await fetch('http://localhost:3000/health'); console.log(r.status, await r.text()); process.exit(r.ok ? 0 : 1)\"",
    "smoke:local": "bun run scripts/smoke-local-api.ts",
    "typecheck": "tsc -b tsconfig.build.json --pretty",
    "lint": "eslint .",
    "format": "prettier --write \"apps/**/*.{json,ts}\" \"packages/**/*.{json,ts}\" \"scripts/**/*.ts\" \"test/**/*.{json,ts}\" \"tests/**/*.{json,ts}\" \"docs/**/*.md\" \"*.json\" \"*.js\"",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "trustedDependencies": [],
  "dependencies": {
    "@mcbanners/banner-renderer": "workspace:*",
    "@mcbanners/cache": "workspace:*",
    "@mcbanners/config": "workspace:*",
    "@mcbanners/db": "workspace:*",
    "@mcbanners/domain": "workspace:*",
    "@mcbanners/external-clients": "workspace:*",
    "@mcbanners/logger": "workspace:*",
    "@mcbanners/minecraft-status": "workspace:*",
    "hono": "^4.12.18",
    "kysely": "^0.29.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.3"
  }
}
