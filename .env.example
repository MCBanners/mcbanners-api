# HTTP
PORT=3000
NODE_ENV=development

# Saved-banner database persistence
SAVED_BANNER_DB_ENABLED=false
# DATABASE_URL=mysql://<user>:<password>@<host>:3306/<database>
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=mcbanners
# DB_PASSWORD=
# DB_NAME=mcbanners_dev
# DB_SSL=false
# DB_POOL_CONNECTION_LIMIT=10

# Optional upstream service credentials
BUILTBYBIT_API_KEY=

# Cache TTLs, in milliseconds
CACHE_MINECRAFT_STATUS_TTL_MS=30000
CACHE_RENDERED_SERVER_BANNER_TTL_MS=60000
CACHE_MARKETPLACE_RESOURCE_TTL_MS=900000
CACHE_RENDERED_RESOURCE_BANNER_TTL_MS=300000
CACHE_MARKETPLACE_AUTHOR_TTL_MS=900000
CACHE_RENDERED_AUTHOR_BANNER_TTL_MS=300000
CACHE_MARKETPLACE_MEMBER_TTL_MS=900000
CACHE_RENDERED_MEMBER_BANNER_TTL_MS=300000
CACHE_MARKETPLACE_TEAM_TTL_MS=900000
CACHE_RENDERED_TEAM_BANNER_TTL_MS=300000

# Rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# Metrics
METRICS_ENABLED=false

# Logging
LOG_LEVEL=info
