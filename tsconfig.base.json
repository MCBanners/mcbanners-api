{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "paths": {
      "@mcbanners/domain": ["./packages/domain/src/index.ts"],
      "@mcbanners/domain/*": ["./packages/domain/src/*"],
      "@mcbanners/config": ["./packages/config/src/index.ts"],
      "@mcbanners/config/*": ["./packages/config/src/*"],
      "@mcbanners/logger": ["./packages/logger/src/index.ts"],
      "@mcbanners/logger/*": ["./packages/logger/src/*"],
      "@mcbanners/cache": ["./packages/cache/src/index.ts"],
      "@mcbanners/cache/*": ["./packages/cache/src/*"],
      "@mcbanners/db": ["./packages/db/src/index.ts"],
      "@mcbanners/db/*": ["./packages/db/src/*"],
      "@mcbanners/banner-renderer": ["./packages/banner-renderer/src/index.ts"],
      "@mcbanners/banner-renderer/*": ["./packages/banner-renderer/src/*"],
      "@mcbanners/external-clients": ["./packages/external-clients/src/index.ts"],
      "@mcbanners/external-clients/*": ["./packages/external-clients/src/*"],
      "@mcbanners/minecraft-status": ["./packages/minecraft-status/src/index.ts"],
      "@mcbanners/minecraft-status/*": ["./packages/minecraft-status/src/*"]
    }
  }
}
